import { Injectable, NotFoundException } from '@nestjs/common'
import { PrismaService } from '../prisma/prisma.service'
import { ProjectType } from '@prisma/client'
import type { CreateProjectDto } from './dto/create-project.dto'
import type { UpdateProjectDto } from './dto/update-project.dto'

@Injectable()
export class ProjectsService {
  constructor(private prisma: PrismaService) {}

  async findAll(categoryId?: string, type?: string) {
    const typeValue =
      type && (Object.values(ProjectType) as string[]).includes(type)
        ? (type as ProjectType)
        : undefined

    return this.prisma.project.findMany({
      where: {
        isPublished: true,
        ...(categoryId  ? { categoryId }        : {}),
        ...(typeValue   ? { type: typeValue }    : {}),
      },
      include: { category: true },
      orderBy: { createdAt: 'desc' },
    })
  }

  async findAllAdmin() {
    return this.prisma.project.findMany({
      include: { category: true },
      orderBy: { createdAt: 'desc' },
    })
  }

  async findOne(id: string) {
    const project = await this.prisma.project.findUnique({
      where: { id },
      include: { category: true },
    })
    if (!project) throw new NotFoundException('Project not found')
    return project
  }

  async create(dto: CreateProjectDto) {
    return this.prisma.project.create({
      data: {
        title:       { zh: dto.titleZh,       en: dto.titleEn },
        description: { zh: dto.descriptionZh, en: dto.descriptionEn },
        type:        dto.type,
        categoryId:  dto.categoryId ?? null,   // ← 直接写 categoryId，不用 connect
        media:       dto.media ?? [],
        price:       dto.price ?? null,
        isPublished: dto.isPublished ?? false,
      },
    })
  }

  async update(id: string, dto: UpdateProjectDto) {
    const current = await this.findOne(id)

    const existingTitle       = current.title as { zh: string; en: string }
    const existingDescription = current.description as { zh: string; en: string }

    return this.prisma.project.update({
      where: { id },
      data: {
        ...(dto.titleZh !== undefined || dto.titleEn !== undefined
          ? { title: { zh: dto.titleZh ?? existingTitle.zh, en: dto.titleEn ?? existingTitle.en } }
          : {}),
        ...(dto.descriptionZh !== undefined || dto.descriptionEn !== undefined
          ? { description: { zh: dto.descriptionZh ?? existingDescription.zh, en: dto.descriptionEn ?? existingDescription.en } }
          : {}),
        ...(dto.type        !== undefined ? { type:       dto.type }       : {}),
        ...(dto.categoryId  !== undefined ? { categoryId: dto.categoryId } : {}),  // ← 同样直接用 categoryId
        ...(dto.media       !== undefined ? { media:      dto.media }      : {}),
        ...(dto.price       !== undefined ? { price:      dto.price }      : {}),
        ...(dto.isPublished !== undefined ? { isPublished: dto.isPublished } : {}),
      },
    })
  }

  async remove(id: string) {
    await this.findOne(id)
    return this.prisma.project.delete({ where: { id } })
  }
}