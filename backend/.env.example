# FlashDev — Environment Variables
# Copy to .env and fill in values

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://flashdev:flashdev_secret@postgres:5432/flashdev?schema=public

# ── Authentication ────────────────────────────────────────────────────────────
# Must match JWT_SECRET in production secrets manager
JWT_SECRET=change_this_to_a_long_random_secret

# ── Mail (Nodemailer) ───────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=demondeer2003@gmail.com
MAIL_PASS=your_app_password_here
MAIL_FROM="FlashDev <contact@flashdev.com>"
